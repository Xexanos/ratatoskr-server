# See docs/SPEC.md section 7 (Configuration) and section 14 (Security) for details.

# Required
ABS_URL=http://192.168.1.50:13378
ABS_STREAMER_USER=ratatoskr-streamer
ABS_STREAMER_PASSWORD=

# Sonos discovery is automatic via SSDP. Only set this on networks where
# multicast/SSDP is unreliable.
#SONOS_SEED_HOST=192.168.1.60

# Optional (defaults shown)
#PORT=8080
#POLL_INTERVAL_SECONDS=15
#SEEK_SETTLE_MS=1000
#SEEK_TOLERANCE_SECONDS=3
#SEEK_RETRIES=2
#PROGRESS_WRITE_THRESHOLD_SECONDS=5

# Validate every response against the OpenAPI contract at runtime (dev/staging aid; off by
# default). Catches contract drift but adds per-response overhead — leave off in production.
#VALIDATE_RESPONSES=true

# TLS (recommended, see section 14). Provide both, or neither plus the explicit opt-out.
#TLS_CERT_PATH=/etc/ratatoskr/tls/cert.pem
#TLS_KEY_PATH=/etc/ratatoskr/tls/key.pem
#ALLOW_PLAIN_HTTP=true
