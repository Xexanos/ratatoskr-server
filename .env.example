# Values for `docker compose` (and local `pnpm dev`). Copy to .env and fill these in.
# What every variable does — including all the optional/TLS/tuning ones — is documented in
# compose.yaml, the single reference; SPEC sections 7 and 14 carry the deeper rationale.

# Required — your Audiobookshelf server.
ABS_URL=https://192.168.1.50:13378
# Required — API key of a dedicated, low-privilege, stream-only ABS account (see the README).
ABS_STREAMER_API_KEY=

# Transport for Ratatoskr's own listener. `true` accepts plain HTTP — use only on a trusted LAN
# or behind a TLS-terminating reverse proxy. To serve HTTPS directly, set this to false and
# configure TLS_CERT_PATH/TLS_KEY_PATH in compose.yaml instead.
ALLOW_PLAIN_HTTP=true

# Optional — pin the image tag compose deploys (default: latest).
#RATATOSKR_IMAGE_TAG=latest

# Any other variable from compose.yaml can be set here too (docker compose reads this file, and
# `pnpm dev`/`start` load it via Node's --env-file). For example:
#SONOS_SEED_HOST=192.168.1.60
#POLL_INTERVAL_SECONDS=15
