# See docs/SPEC.md section 7 (Configuration) and section 14 (Security) for details.

# Required. Use https:// so credentials and tokens are not sent in cleartext (SPEC section 14).
ABS_URL=https://192.168.1.50:13378
# Required. An Audiobookshelf API key for a dedicated, stream-only account (SPEC section 14).
# It is embedded in the media URLs handed to the speakers, so it must be low-privilege: create a
# user with no download/upload/delete and access only to the audiobook library, then generate an
# API key for it (Settings -> Users -> API Keys) and paste it here. Never the listening user's.
ABS_STREAMER_API_KEY=

# Audiobookshelf transport (SPEC section 14).
# Accept a plain-HTTP ABS_URL (credentials cross the network in cleartext) — only on a trusted
# LAN or when TLS is terminated by a reverse proxy:
#ABS_ALLOW_PLAIN_HTTP=true
# Trust a self-signed / private-CA ABS certificate: give the PEM as a file path OR inline
# (set only one). Verification stays on.
#ABS_CA_CERT_PATH=/etc/ratatoskr/tls/abs-ca.pem
#ABS_CA_CERT="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"
# Last resort: disable ABS certificate verification entirely (vulnerable to MITM). Mutually
# exclusive with the ABS_CA_CERT* options above.
#ABS_TLS_INSECURE=true

# Sonos discovery is automatic via SSDP. Only set this on networks where
# multicast/SSDP is unreliable.
#SONOS_SEED_HOST=192.168.1.60

# Optional (defaults shown)
#PORT=8080
#POLL_INTERVAL_SECONDS=15
#SEEK_SETTLE_MS=1000
#SEEK_TOLERANCE_SECONDS=3
#SEEK_RETRIES=2
#PROGRESS_WRITE_THRESHOLD_SECONDS=5
# How far before the listening user's ABS access token expires the sync loop renews it (SPEC §8).
#LISTENING_TOKEN_REFRESH_MARGIN_SECONDS=300
# Upper bound on the graceful-shutdown drain before the process exits anyway (SPEC §5).
#SHUTDOWN_TIMEOUT_MS=5000

# Validate every response against the OpenAPI contract at runtime (dev/staging aid; off by
# default). Catches contract drift but adds per-response overhead — leave off in production.
#VALIDATE_RESPONSES=true

# TLS (recommended, see section 14). Provide both, or neither plus the explicit opt-out.
#TLS_CERT_PATH=/etc/ratatoskr/tls/cert.pem
#TLS_KEY_PATH=/etc/ratatoskr/tls/key.pem
#ALLOW_PLAIN_HTTP=true
