# FOR LOCAL DEVELOPMENT ONLY. `pnpm dev` and `pnpm --filter @ratatoskr/app start` load this file
# via Node's --env-file. Copy it to .env and fill in your values.
#
# Deploying with Docker? You do NOT need this file — set the variables directly in the
# `environment:` block of compose.yaml, which documents every option.

# Required — your Audiobookshelf server.
ABS_URL=https://192.168.1.50:13378
# Required — API key of a dedicated, low-privilege, stream-only ABS account (see the README).
ABS_STREAMER_API_KEY=

# Ratatoskr's own listener. Locally the simplest option is plain HTTP; for HTTPS set
# TLS_CERT_PATH/TLS_KEY_PATH instead. (Unlike the container, `pnpm dev` does not auto-generate a
# certificate — that convenience lives only in the Docker entrypoint.)
ALLOW_PLAIN_HTTP=true

# Any other variable the server understands can be set here too. The full list, with defaults and
# explanations, lives in compose.yaml; SPEC sections 7 and 14 carry the deeper rationale. Examples:
#SONOS_SEED_HOST=192.168.1.60
#POLL_INTERVAL_SECONDS=15
