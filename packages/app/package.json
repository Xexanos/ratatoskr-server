{
  "name": "@ratatoskr/app",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "GPL-3.0-or-later",
  "main": "./dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "dev": "tsx watch --env-file-if-exists=../../.env src/main.ts",
    "start": "node --env-file-if-exists=../../.env dist/main.js"
  },
  "dependencies": {
    "@ratatoskr/contract": "workspace:*",
    "@svrooij/sonos": "^2.5.0",
    "fastify": "^5.2.1",
    "fastify-openapi-glue": "^4.11.3",
    "undici": "^6.27.0"
  },
  "devDependencies": {
    "@fastify/response-validation": "^3.0.3",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^26.1.0",
    "@vitest/coverage-v8": "^4.1.9",
    "ajv": "^8.17.1",
    "js-yaml": "^5.2.1",
    "testcontainers": "^12.0.4",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
