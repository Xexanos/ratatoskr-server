{
  "name": "@ratatoskr/app",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "GPL-3.0-or-later",
  "main": "./dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "dev": "tsx watch --env-file-if-exists=../../.env src/main.ts",
    "start": "node --env-file-if-exists=../../.env dist/main.js"
  },
  "dependencies": {
    "@ratatoskr/contract": "workspace:*",
    "fastify": "^5.2.1"
  },
  "devDependencies": {
    "@fastify/response-validation": "^3.0.3",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.7",
    "ajv": "^8.17.1",
    "js-yaml": "^5.2.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.4",
    "@vitest/coverage-v8": "^3.0.4"
  }
}
