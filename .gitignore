# Dependencies
node_modules/

# This is a pnpm workspace — foreign package-manager lockfiles must never be committed
# (pnpm-lock.yaml is the single lockfile). Guards against a stray `npm install`/`yarn` in a package.
package-lock.json
yarn.lock

# Build output
dist/
build/
coverage/

# Generated from contract/openapi.yaml — never hand-edited, regenerated by `pnpm generate`
packages/contract/src/generated/

# Logs
*.log
npm-debug.log*

# Environment / secrets
.env
.env.*
!.env.example

# Editor / OS
.idea/
.vscode/
.DS_Store
Thumbs.db
